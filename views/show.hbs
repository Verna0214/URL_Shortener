<html>

<body>
  <div class="container text-center" style="margin-top: 50px;">
    <div class="row g-2">
      <div class="title" style="mt-8">
        <h1>URL Shortener</h1>
      </div>
    </div>
    <div class="image">
      <img src="https://assets-lighthouse.alphacamp.co/uploads/image/file/16716/ExportedContentImage_00.png" alt="image"
        style="height: 200px; width: 200px; margin-top: 30px">
    </div>
    <div class="mb-3; mt-5">
      <h1>Success! Please use this link :</h1>
      <a href="{{ urlShorten }}"><input type="url" name="urlShorten" id="urlShorten" class="form-control"
          style="font-size: 26px; color: rgb(68, 86, 225); size: 8; text-align: center; border: none;"
          value="{{ urlShorten }}"></a>
    </div>
    <button onclick="copyOnclick()" class="btn btn-primary mt-4" id="copyBtn" style="width: 100px;">Copy</button>
    <a href="/"><button type="button" class="btn btn-secondary mt-4" style="width: 100px;">Back</button></a>
  </div>
</body>

</html>